# Ozon API credentials
OZON_CLIENT_ID=test_client_id
OZON_API_KEY=test_api_key

# Database URL (SQLite for demo, PostgreSQL for production)
DATABASE_URL=sqlite+aiosqlite:///./ozon_analytics.db

# Commission and fees (in percent)
DEFAULT_COMMISSION_PERCENT=10.0
ECOMMERCE_FEE_PERCENT=2.0
TAX_PERCENT=6.0

# Logistics rates (in RUB)
LOGISTICS_BASE_RATE=50.0
LOGISTICS_PER_KG_RATE=30.0

# API Rate Limiting (requests per second)
OZON_RATE_LIMIT=15
OZON_TIMEOUT=30

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/ozon_analytics.log

# Scheduler (sync interval in minutes)
SYNC_INTERVAL_MINUTES=60

# Cost file path (CSV with SKU and cost price)
COST_FILE_PATH=data/costs.csv
